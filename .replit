modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.development]
AI_INTEGRATIONS_OPENAI_BASE_URL = "https://placeholder.local/v1"
AI_INTEGRATIONS_OPENAI_API_KEY = "placeholder-key"

[userenv.shared]
